# TourCrafts Backend Configuration

# Database
DATABASE_URL=mysql+mysqlconnector://root:your_password@localhost:3306/tourcrafts_db

# App Settings
APP_NAME=TourCrafts API
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# WhatsApp Business API (for lead notifications)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE=919876543210

# Email Settings (for lead notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Frontend URL
FRONTEND_URL=http://localhost:3000
